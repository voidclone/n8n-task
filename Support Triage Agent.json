        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ text: `:rotating_light: High-urgency ticket ${$json.ticket_id} from ${$json.customer_name} (${$json.email})\\nCategory: ${$json.category}\\nSentiment: ${$json.sentiment}\\nSummary: ${$json.summary}` }) }}",
        "options": {}
      },
