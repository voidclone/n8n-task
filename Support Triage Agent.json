              "value": "={{ JSON.parse($json.output).category }}"
            },
            {
              "id": "b2",
              "name": "urgency",
              "type": "string",
              "value": "={{ JSON.parse($json.output).urgency }}"
            },
            {
              "id": "b3",
              "name": "sentiment",
              "type": "string",
              "value": "={{ JSON.parse($json.output).sentiment }}"
            },
            {
              "id": "b4",
              "name": "requested_action",
              "type": "string",
              "value": "={{ JSON.parse($json.output).requested_action }}"
            },
            {
              "id": "b5",
              "name": "summary",
              "type": "string",
              "value": "={{ JSON.parse($json.output).summary }}"
            },
            {
              "id": "b6",
              "name": "ticket_id",
              "type": "string",
              "value": "={{ $('Normalize Input').item.json.ticket_id }}"
            },
            {
              "id": "b7",
              "name": "customer_name",
              "type": "string",
              "value": "={{ $('Normalize Input').item.json.customer_name }}"
            },
            {
