            {
              "id": "a1",
              "name": "customer_name",
              "type": "string",
              "value": "={{ $json.body.customer_name.trim() }}"
            },
            {
              "id": "a2",
              "name": "email",
              "type": "string",
              "value": "={{ $json.body.email.trim().toLowerCase() }}"
            },
            {
              "id": "a3",
              "name": "message",
              "type": "string",
              "value": "={{ $json.body.message.trim() }}"
            },
            {
              "id": "a4",
              "name": "channel",
              "type": "string",
              "value": "={{ $json.body.channel || 'unknown' }}"
            },
            {
              "id": "a5",
              "name": "received_at",
              "type": "string",
              "value": "={{ $now.toISO() }}"
            },
            {
              "id": "a6",
              "name": "ticket_id",
              "type": "string",
              "value": "=TCK-{{ Math.floor(Math.random() * 90000 + 10000) }}"
            }
          ]
        },
        "options": {}
      },
      "id": "a0aa7a96-2557-4177-b3a5-9ebb9545c7e5",
      "name": "Normalize Input",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        -864,
        80
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Customer message: \"{{ $json.message }}\"\nChannel: {{ $json.channel }}",
        "options": {
          "systemMessage": "You are a support triage assistant. Read the customer message and extract structured details. Respond ONLY with valid JSON, no prose, no markdown fences, matching exactly this shape:\n{\n  \"category\": string,        // e.g. shipping_delay, billing, bug_report, account_access, other\n  \"urgency\": \"low\" | \"medium\" | \"high\",\n  \"sentiment\": \"neutral\" | \"frustrated\" | \"angry\" | \"positive\",\n  \"requested_action\": string,\n  \"summary\": string           // one sentence\n}"
        }
      },
      "id": "63b2dd59-a78f-4794-b9fd-669ec19fbf23",
      "name": "AI Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [
        -688,
        -16
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "b1",
              "name": "category",
